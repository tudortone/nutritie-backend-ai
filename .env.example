# Exemplu de configurare variabile de mediu pentru serverul NutriAI Backend
PORT=3000
HOST=0.0.0.0

# Chei API Google Gemini (opțional se pot seta chei de rotație GEMINI_API_KEY_2, _3, _4)
GEMINI_API_KEY=cheia_ta_gemini
# Opțional: Modelul Gemini preferat (ex: gemini-2.5-flash). Dacă lipsește sau e greșit, cascada folosește modelele stabile de fallback.
GEMINI_MODEL=gemini-2.5-flash

# Cheie API Groq (pentru text/chat rapid)
GROQ_API_KEY=cheia_ta_groq

# Cheie API OpenAI (pentru fallback opțional)
OPENAI_API_KEY=cheia_ta_openai

# Supabase (pentru validare token JWT și acces la baza de date)
SUPABASE_URL=https://proiectul-tau.supabase.co
SUPABASE_ANON_KEY=cheia_anon_sau_publishable

# Setări CORS (domenii permise sau * pentru dev)
CORS_ORIGINS=*
